# Copy this to .streamlit/secrets.toml and fill in your values.
# secrets.toml is gitignored — never commit real credentials.

# ── dbt Semantic Layer ─────────────────────────────────────────────────────────
DBT_SL_ENVIRONMENT_ID = "335860"
DBT_SL_AUTH_TOKEN     = "dbtu_..."
DBT_SL_HOST           = "hy250.semantic-layer.us1.dbt.com"

# ── Snowflake ──────────────────────────────────────────────────────────────────
SNOWFLAKE_ACCOUNT   = "your_account.snowflakecomputing.com"
SNOWFLAKE_USER      = "your_user"
SNOWFLAKE_PASSWORD  = "your_password"
SNOWFLAKE_WAREHOUSE = "COMPUTE_WH"
SNOWFLAKE_DATABASE  = "ANALYTICS"
SNOWFLAKE_SCHEMA    = "PUBLIC"
SNOWFLAKE_ROLE      = "ANALYST_ROLE"

# ── Feedback storage (must match schema.sql) ───────────────────────────────────
SNOWFLAKE_FEEDBACK_DB     = "ANALYTICS"
SNOWFLAKE_FEEDBACK_SCHEMA = "SEMANTIC_DEMO_FEEDBACK"

# ── Agent tuning ───────────────────────────────────────────────────────────────
# Available Snowflake Cortex models:
#   claude-3-5-sonnet  (best quality, Anthropic)
#   llama3.1-70b       (fast, open-source)
#   mistral-large2     (good balance)
CORTEX_MODEL    = "claude-3-5-sonnet"
MAX_RESULT_ROWS = "10000"
